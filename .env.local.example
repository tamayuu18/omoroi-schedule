NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 既存CRM(別Supabase)連携。未設定ならCRM連携はスキップされる。
CRM_SUPABASE_URL=your_crm_supabase_url
CRM_SUPABASE_SERVICE_KEY=your_crm_service_key

# 提携会社経由の代理予約で使われる「本人を識別しない」共通メアド（カンマ区切り）。
# これらのアドレスではメアド照合せず、求職者本人の電話番号→氏名で照合する。
# 未設定時のデフォルトは lreach_schedule@foresma.jp。
CRM_PROXY_EMAILS=lreach_schedule@foresma.jp
